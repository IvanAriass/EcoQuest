<Window
    x:Class="PrototipadoEscritorio.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PrototipadoEscritorio.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PrototipadoEscritorio.ViewModels"
    Title="Base"
    Width="1400"
    Height="900"
    mc:Ignorable="d">

    <Window.DataContext>
        <vm:MainWindowVM />
    </Window.DataContext>

    <Grid>

        <!--  FONDO  -->
        <Grid.Background>
            <ImageBrush
                AlignmentX="Center"
                AlignmentY="Center"
                ImageSource="/Assets/Fondo.png"
                Stretch="UniformToFill" />
        </Grid.Background>

        <!--  LAYOUT PRINCIPAL  -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  SIDEBAR  -->
            <Border Grid.Column="0" Background="#1E3A2E">

                <!--  SCROLL POR SI LA VENTANA ES MUY PEQUEÑA  -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  LOGO  -->
                        <StackPanel
                            Grid.Row="0"
                            Margin="0,20,0,20"
                            HorizontalAlignment="Center">

                            <Border
                                Width="123"
                                Height="123"
                                BorderThickness="2"
                                CornerRadius="20">
                                <Border.Clip>
                                    <RectangleGeometry
                                        RadiusX="20"
                                        RadiusY="20"
                                        Rect="0,0,123,123" />
                                </Border.Clip>

                                <Image Source="/Assets/logo.png" />

                            </Border>

                        </StackPanel>

                        <!--  BOTONES  -->
                        <Grid Grid.Row="1">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Button
                                Grid.Row="0"
                                Command="{Binding AbrirVentanaUsuariosCommand}"
                                Style="{StaticResource SidebarButton}">

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="28"
                                        Text="👤" />
                                    <TextBlock Margin="0,4,0,0" Text="Usuarios" />
                                </StackPanel>

                            </Button>

                            <Button
                                Grid.Row="1"
                                Command="{Binding AbrirVentanaEventosCommand}"
                                Style="{StaticResource SidebarButton}">

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="28"
                                        Text="🏠" />
                                    <TextBlock Margin="0,4,0,0" Text="Eventos" />
                                </StackPanel>

                            </Button>

                            <Button
                                Grid.Row="2"
                                Command="{Binding AbrirVentanaComunidadesCommand}"
                                Style="{StaticResource SidebarButton}">

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="28"
                                        Text="📄" />
                                    <TextBlock Margin="0,4,0,0" Text="Comunidades" />
                                </StackPanel>

                            </Button>

                            <Button
                                Grid.Row="3"
                                Command="{Binding AbrirVentanaAccesoriosCommand}"
                                Style="{StaticResource SidebarButton}">

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="28"
                                        Text="🛒" />
                                    <TextBlock Margin="0,4,0,0" Text="Tienda" />
                                </StackPanel>

                            </Button>

                        </Grid>

                    </Grid>

                </ScrollViewer>

            </Border>

            <!--  CONTENIDO PRINCIPAL  -->
            <ContentControl Grid.Column="1" Content="{Binding ContenidoVentana}" />

        </Grid>

    </Grid>
</Window>