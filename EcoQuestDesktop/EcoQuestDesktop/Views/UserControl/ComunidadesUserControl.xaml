<UserControl
    x:Class="PrototipadoEscritorio.Views.ComunidadesUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PrototipadoEscritorio.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PrototipadoEscritorio.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:ComunidadesUserControlVM />
    </UserControl.DataContext>

    <Grid>
        <ContentControl
            Grid.Column="1"
            Margin="60,120,60,60"
            Content="{Binding ContenidoVentana}" />

        <DockPanel
            x:Name="MenuDockPanel"
            Width="200"
            HorizontalAlignment="Left"
            Background="White"
            Opacity="0.8"
            Visibility="{Binding IsDockVisible, Converter={StaticResource BoolToVisibilityConverter}}">

            <StackPanel
                Margin="0,70,0,0"
                HorizontalAlignment="Center"
                DockPanel.Dock="Left"
                Orientation="Vertical">

                <TextBlock
                    Padding="20"
                    HorizontalAlignment="Center"
                    FontSize="34">
                    Opciones
                </TextBlock>

                <Button
                    HorizontalAlignment="Center"
                    Command="{Binding AbrirListadoComunidadesCommand}"
                    Style="{DynamicResource BotonesMenuHamburguesa}">
                    Lista de Comunidades
                </Button>

                <Button
                    HorizontalAlignment="Center"
                    Command="{Binding AbrirAñadirComunidadCommand}"
                    Style="{DynamicResource BotonesMenuHamburguesa}">
                    Añadir Comunidad
                </Button>

                <Button
                    HorizontalAlignment="Center"
                    Command="{Binding AbrirRevisarComunidadCommand}"
                    Style="{DynamicResource BotonesMenuHamburguesa}">
                    Revisar Comunidad
                </Button>

                <Button
                    HorizontalAlignment="Center"
                    Command="{Binding AbrirEliminarComunidadCommand}"
                    Style="{DynamicResource BotonesMenuHamburguesa}">
                    Eliminar Comunidad
                </Button>
            </StackPanel>
        </DockPanel>

        <Grid
            Grid.Column="1"
            Margin="20"
            VerticalAlignment="Top">
            <Grid>
                <Button
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding ToggleDockCommand}"
                    Content="☰"
                    Cursor="Hand"
                    FontSize="30" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>