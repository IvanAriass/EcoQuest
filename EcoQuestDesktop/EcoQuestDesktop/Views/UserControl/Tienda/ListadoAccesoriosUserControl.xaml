<UserControl
    x:Class="PrototipadoEscritorio.Views.ListadoAccesoriosUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PrototipadoEscritorio.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PrototipadoEscritorio.ViewModels.Tienda"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:ListadoAccesoriosVM />
    </UserControl.DataContext>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  Título  -->
                <RowDefinition Height="Auto" />
                <!--  Buscador  -->
                <RowDefinition Height="*" />
                <!--  WrapPanel con scroll  -->
            </Grid.RowDefinitions>

            <!--  ====================== TÍTULO ======================  -->
            <Label
                Grid.Row="0"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                Content="Accesorios"
                FontSize="52" />

            <!--  ====================== BUSCADOR ======================  -->
            <Grid
                Grid.Row="1"
                Width="600"
                Height="40"
                Margin="0,0,0,40">
                <Border
                    Padding="12,0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#888"
                            Text="🔍" />
                        <TextBox
                            x:Name="SearchBox"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="14"
                            Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>
                <TextBlock
                    Margin="48,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#999"
                    IsHitTestVisible="False"
                    Text="Buscar accesorio"
                    Visibility="{Binding Text.IsEmpty, ElementName=SearchBox, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <!--  ====================== SCROLL + WRAP PANEL ======================  -->
            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">

                <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding ListaProductos}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Grid Style="{StaticResource CardWrapperStyle}">

                                <!--  🔲 Capa sombra: solo renderiza la sombra  -->
                                <Border Style="{StaticResource CardShadowLayerStyle}" />

                                <!--  🃏 Capa contenido: todo el contenido real, sin Effect  -->
                                <Border Style="{StaticResource CardContentLayerStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            Grid.Row="0"
                                            Style="{StaticResource CardTitleStyle}"
                                            Text="{Binding Nombre}" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Style="{StaticResource CardSubTextStyle}"
                                            Text="{Binding Precio, StringFormat='{}{0} pts'}" />

                                        <Border Grid.Row="2" Style="{StaticResource CardImageContainerStyle}">
                                            <Image
                                                Width="120"
                                                Height="120"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Source="{Binding Imagen}"
                                                Stretch="Uniform" />
                                        </Border>

                                        <Button
                                            Grid.Row="3"
                                            Command="{Binding DataContext.AbrirEditarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Editar"
                                            Style="{StaticResource CardButtonStyle}" />
                                    </Grid>
                                </Border>

                            </Grid>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!--  ====================== OVERLAY + MODAL ======================  -->
        <Grid Visibility="{Binding DataContext.ModalVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}">

            <Button
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding CerrarModalCommand}"
                Cursor="Arrow"
                Focusable="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Rectangle Fill="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <local:EditarAccesorioModalUserControl
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DataContext="{Binding ModalVM}" />

        </Grid>
    </Grid>

</UserControl>
