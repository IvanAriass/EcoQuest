<UserControl
    x:Class="EcoQuestDesktop.Views.ListadoEliminarUsuariosUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:EcoQuestDesktop.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:EcoQuestDesktop.ViewModels.Usuarios"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    UseLayoutRounding="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:ListadoEliminarUsuariosVM />
    </UserControl.DataContext>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Label
                Grid.Row="0"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                Content="Eliminar Usuarios"
                FontSize="52" />

            <Grid
                Grid.Row="1"
                Width="600"
                Height="40"
                Margin="0,0,0,40">
                <Border
                    Padding="12,0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#888"
                            Text="🔍" />
                        <TextBox
                            x:Name="SearchBox"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="14"
                            Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>
                <TextBlock
                    Margin="48,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#999"
                    IsHitTestVisible="False"
                    Text="Buscar usuario"
                    Visibility="{Binding Text.IsEmpty, ElementName=SearchBox, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                SnapsToDevicePixels="True">

                <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding ListaUsuarios}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Width="450"
                                Margin="10"
                                Padding="0"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding
                                        Command="{Binding DataContext.VerDetalleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Gesture="LeftClick" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect
                                                    BlurRadius="8"
                                                    Opacity="0.1"
                                                    ShadowDepth="2" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect
                                                            BlurRadius="18"
                                                            Opacity="0.22"
                                                            ShadowDepth="6" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column="0"
                                        Width="16"
                                        Background="{Binding ColorBorde}"
                                        CornerRadius="12,0,0,12" />

                                    <Grid Grid.Column="1" Margin="16">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border
                                                Width="70"
                                                Height="70"
                                                Margin="0,0,16,0"
                                                Background="#F0F0F0"
                                                BorderBrush="#E0E0E0"
                                                BorderThickness="1"
                                                CornerRadius="35">
                                                <Border.Clip>
                                                    <EllipseGeometry Center="35,35" RadiusX="35" RadiusY="35" />
                                                </Border.Clip>
                                                <Image
                                                    Source="{Binding Imagen}"
                                                    Stretch="UniformToFill" />
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="16"
                                                    FontWeight="SemiBold"
                                                    Foreground="#333"
                                                    Text="{Binding NombreCompleto}" />
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="14"
                                                    Foreground="#007ACC"
                                                    Text="{Binding NombreUsuario, StringFormat='@{0}'}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    FontSize="12"
                                                    Foreground="#888"
                                                    Text="{Binding Email}"
                                                    TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>

                                        <Button
                                            Grid.Row="1"
                                            Height="36"
                                            Margin="0,12,0,0"
                                            HorizontalAlignment="Right"
                                            Command="{Binding DataContext.EliminarUsuarioCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Eliminar"
                                            Cursor="Hand"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Background="IndianRed"
                                            BorderThickness="0"
                                            Padding="18,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        Padding="{TemplateBinding Padding}"
                                                        Background="{TemplateBinding Background}"
                                                        BorderThickness="0"
                                                        CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#CD5C5C" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter Property="Background" Value="#B22222" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid Visibility="{Binding ModalVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding CerrarModalCommand}"
                Cursor="Arrow"
                Focusable="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Rectangle Fill="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <local:EliminarUsuarioUserControl
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DataContext="{Binding EliminarUsuarioVM}" />
        </Grid>

        <Grid Visibility="{Binding DetalleModalVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding CerrarDetalleCommand}"
                Cursor="Arrow"
                Focusable="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Rectangle Fill="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <local:DetalleUsuarioUserControl
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DataContext="{Binding DetalleUsuarioVM}" />
        </Grid>
    </Grid>
</UserControl>
