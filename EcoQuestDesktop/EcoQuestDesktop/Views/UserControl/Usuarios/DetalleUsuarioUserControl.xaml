<UserControl
    x:Class="PrototipadoEscritorio.Views.DetalleUsuarioUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="560"
    d:DesignWidth="440"
    mc:Ignorable="d">

    <Border
        Width="420"
        MaxHeight="640"
        Background="White"
        BorderBrush="#E0E0E0"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="16"
                Opacity="0.25"
                ShadowDepth="4" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Height="130"
                Background="{Binding Usuario.ColorBorde}"
                CornerRadius="16,16,0,0" />

            <Grid Grid.Row="1" Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Width="90"
                    Height="90"
                    Margin="0,-45,0,0"
                    HorizontalAlignment="Center"
                    Background="#F0F0F0"
                    BorderBrush="White"
                    BorderThickness="4"
                    CornerRadius="45"
                    RenderOptions.BitmapScalingMode="HighQuality">
                    <Border.Clip>
                        <EllipseGeometry Center="45,45" RadiusX="45" RadiusY="45" />
                    </Border.Clip>
                    <Image
                        Source="{Binding UrlAvatar}"
                        Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#4F6F8F"
                        Text="{Binding Usuario.NombreUsuario, StringFormat='@{0}'}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="15"
                        Foreground="#555"
                        Text="{Binding NombreMostrar}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="13"
                        Foreground="#888"
                        Text="{Binding EdadMostrar}" />
                </StackPanel>

                <Border
                    Grid.Row="2"
                    Height="1"
                    Margin="30,14,30,0"
                    Background="#E8E8E8" />

                <StackPanel
                    Grid.Row="3"
                    Margin="24,16,24,0">
                    <WrapPanel HorizontalAlignment="Center">
                        <Border
                            Margin="4"
                            Padding="14,8"
                            Background="#F0F4F8"
                            BorderBrush="#D5DDE6"
                            BorderThickness="1"
                            CornerRadius="20">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Text="✉️" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#4F6F8F"
                                    FontWeight="SemiBold"
                                    Text="{Binding Usuario.Email}" />
                            </StackPanel>
                        </Border>
                        <Border
                            Margin="4"
                            Padding="14,8"
                            Background="#F0F4F8"
                            BorderBrush="#D5DDE6"
                            BorderThickness="1"
                            CornerRadius="20">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Text="🎂" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="#4F6F8F"
                                    FontWeight="SemiBold"
                                    Text="{Binding EdadMostrar}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <Border
                        Margin="0,16,0,0"
                        CornerRadius="10">
                        <Grid>
                            <Border
                                Background="{Binding Usuario.ColorBorde}"
                                Opacity="0.12"
                                CornerRadius="10" />
                            <Border
                                Padding="16"
                                BorderBrush="{Binding Usuario.ColorBorde}"
                                BorderThickness="1"
                                CornerRadius="10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            Text="📝" />
                                        <TextBlock
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{Binding Usuario.ColorBorde}"
                                            Text="DESCRIPCIÓN" />
                                    </StackPanel>
                                    <Border
                                        Height="1"
                                        Margin="0,8,0,0"
                                        Background="#E4E9E6" />
                                    <TextBlock
                                        Margin="0,10,0,0"
                                        FontSize="13"
                                        Foreground="#555"
                                        Text="{Binding Usuario.Descripcion}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

                <Button
                    Grid.Row="4"
                    Height="36"
                    Margin="24,14,24,18"
                    Padding="20,0"
                    HorizontalAlignment="Right"
                    BorderThickness="0"
                    Command="{Binding CerrarCommand}"
                    Content="Cerrar"
                    Cursor="Hand"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="White">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{Binding Usuario.ColorBorde}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderThickness="0"
                                            CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
