<UserControl
    x:Class="EcoQuestDesktop.Views.AñadirUsuarioUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:EcoQuestDesktop.ViewModels.Usuarios"
    d:DesignHeight="650"
    d:DesignWidth="700"
    mc:Ignorable="d">

    <UserControl.DataContext>
        <vm:AñadirUsuarioUserControlVM />
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="460"
            HorizontalAlignment="Center"
            VerticalAlignment="Top">
            <TextBlock
                Margin="0,40,0,28"
                Style="{StaticResource FormTitleText}"
                Text="Añadir Usuario" />

            <Border
                Padding="24,20"
                Style="{StaticResource FormCard}">

                <Grid Width="350">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Row 0: Nombre de usuario  -->
                    <StackPanel
                        Grid.Row="0"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,12">
                        <TextBlock
                            Margin="0,0,0,5"
                            Style="{StaticResource FormLabel}"
                            Text="Nombre de usuario" />
                        <Border Style="{StaticResource FormInputBorder}">
                            <TextBox
                                Height="36"
                                Padding="12,0"
                                VerticalContentAlignment="Center"
                                Style="{StaticResource FormTextBox}"
                                Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <!--  Row 1: Nombre + Apellido  -->
                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,0,12">
                        <TextBlock
                            Margin="0,0,0,5"
                            Style="{StaticResource FormLabel}"
                            Text="Nombre" />
                        <Border Style="{StaticResource FormInputBorder}">
                            <TextBox
                                Height="36"
                                Padding="12,0"
                                VerticalContentAlignment="Center"
                                Style="{StaticResource FormTextBox}"
                                Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,0,0,12">
                        <TextBlock
                            Margin="0,0,0,5"
                            Style="{StaticResource FormLabel}"
                            Text="Apellido" />
                        <Border Style="{StaticResource FormInputBorder}">
                            <TextBox
                                Height="36"
                                Padding="12,0"
                                VerticalContentAlignment="Center"
                                Style="{StaticResource FormTextBox}"
                                Text="{Binding Apellido, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <!--  Row 2: Email + FechaNacimiento (3:1)  -->
                    <StackPanel
                        Grid.Row="2"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="5*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    Style="{StaticResource FormLabel}"
                                    Text="Email" />
                                <Border Style="{StaticResource FormInputBorder}">
                                    <TextBox
                                        Height="36"
                                        Padding="12,0"
                                        VerticalContentAlignment="Center"
                                        Style="{StaticResource FormTextBox}"
                                        Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock
                                    Margin="0,0,0,5"
                                    Style="{StaticResource FormLabel}"
                                    Text="Fecha de nacimiento" />
                                <DatePicker SelectedDate="{Binding FechaNacimiento, TargetNullValue={x:Null}}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!--  Row 3: Contraseña  -->
                    <StackPanel
                        Grid.Row="3"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,12">
                        <TextBlock
                            Margin="0,0,0,5"
                            Style="{StaticResource FormLabel}"
                            Text="Contraseña" />
                        <Border Style="{StaticResource FormInputBorder}">
                            <TextBox
                                Height="36"
                                Padding="12,0"
                                VerticalContentAlignment="Center"
                                Style="{StaticResource FormTextBox}"
                                Text="{Binding Contraseña, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <!--  Row 4: Descripción  -->
                    <StackPanel
                        Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,12">
                        <TextBlock
                            Margin="0,0,0,5"
                            Style="{StaticResource FormLabel}"
                            Text="Descripción" />
                        <Border Style="{StaticResource FormInputBorder}">
                            <TextBox
                                Height="50"
                                Padding="12,6"
                                Style="{StaticResource FormMultiTextBox}"
                                Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <!--  Row 5: Separator  -->
                    <Border
                        Grid.Row="5"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,14"
                        Style="{StaticResource FormSeparator}" />

                    <!--  Row 6: Imagen de perfil  -->
                    <StackPanel
                        Grid.Row="6"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,16">
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource FormLabel}"
                                Text="Imagen de perfil" />
                            <Button
                                HorizontalAlignment="Right"
                                DockPanel.Dock="Right"
                                Style="{StaticResource FormImageSelectButton}"
                                Command="{Binding SeleccionarImagenCommand}"
                                Content="Seleccionar" />
                        </DockPanel>

                        <TextBlock
                            Margin="0,0,0,8"
                            Style="{StaticResource FormImagePathText}"
                            Text="{Binding RutaImagenLocal, FallbackValue='Ninguna imagen seleccionada', TargetNullValue='Ninguna imagen seleccionada'}" />

                        <Border
                            Width="100"
                            Height="100"
                            HorizontalAlignment="Left"
                            Style="{StaticResource FormImagePreviewBox}">
                            <Image Source="{Binding Previsualizacion}" Stretch="Uniform" />
                        </Border>
                    </StackPanel>

                    <!--  Row 7: Guardar  -->
                    <Button
                        Grid.Row="7"
                        Grid.ColumnSpan="3"
                        HorizontalAlignment="Right"
                        Style="{StaticResource FormGuardarButton}"
                        Command="{Binding GuardarCommand}"
                        Content="Guardar" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
