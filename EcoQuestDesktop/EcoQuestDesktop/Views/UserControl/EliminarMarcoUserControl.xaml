<UserControl x:Class="PrototipadoEscritorio.Views.EliminarMarcoUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PrototipadoEscritorio.Views"
             mc:Ignorable="d" 
             d:DesignHeight="150" d:DesignWidth="500">
 
    <Border CornerRadius="10" Background="White">
        <Grid>

            <!-- Definición de filas -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Encabezado -->
                <RowDefinition Height="*"/>
                <!-- Confirmación -->
                <RowDefinition Height="Auto"/>
                <!-- Botones -->
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <TextBlock Grid.Row="0"
                   Text="{Binding Producto.Nombre, StringFormat='Eliminar: {0}'}"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White"
                   Background="#AF4C4E"
                   Padding="10"
                   HorizontalAlignment="Stretch"
                   TextAlignment="Center"/>

            <!-- Texto de confirmación -->
            <!--<TextBlock Grid.Row="1"
                   Text="{Binding Producto.Nombre, StringFormat=¿Estás seguro de que quieres eliminar a '{0}'?}"
                   Margin="10,20,10,5"
                   TextWrapping="Wrap"
                   FontSize="18"/>-->

            <!-- Botones -->
            <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,10,10">

                <Button Content="Cancelar"
                    Width="80"
                    Margin="0,0,10,0"
                    Background="Black"
                    Foreground="White"
                    Command="{Binding CancelarCommand}"/>

                <Button Content="Confirmar"
                    Width="80"
                    Background="#AF4C4E"
                    Foreground="White"
                    Command="{Binding ConfirmarCommand}"/>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
