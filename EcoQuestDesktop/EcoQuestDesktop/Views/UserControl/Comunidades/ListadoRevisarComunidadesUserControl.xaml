<UserControl
    x:Class="PrototipadoEscritorio.Views.ListadoRevisarComunidadesUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PrototipadoEscritorio.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PrototipadoEscritorio.ViewModels.Comunidades"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:ListadoRevisarComunidadesVM />
    </UserControl.DataContext>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Label
                Grid.Row="0"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                Content="Revisar Comunidades"
                FontSize="52" />

            <Grid
                Grid.Row="1"
                Width="600"
                Height="40"
                Margin="0,0,0,40">
                <Border
                    Padding="12,0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#888"
                            Text="🔍" />
                        <TextBox
                            x:Name="SearchBox"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="14"
                            Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>
                <TextBlock
                    Margin="48,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#999"
                    IsHitTestVisible="False"
                    Text="Buscar comunidad"
                    Visibility="{Binding Text.IsEmpty, ElementName=SearchBox, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">

                <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding ListaComunidades}">
                    <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Style="{StaticResource CardWrapperStyle}">
                            <Grid.InputBindings>
                                <MouseBinding
                                    Command="{Binding DataContext.VerDetalleComunidadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Gesture="LeftClick" />
                            </Grid.InputBindings>
                            <Border Style="{StaticResource CardShadowLayerStyle}" />
                            <Border Style="{StaticResource CardContentLayerStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock
                                        Grid.Row="0"
                                        Style="{StaticResource CardTitleStyle}"
                                        Text="{Binding Nombre}" />

                                    <Border Grid.Row="1" Style="{StaticResource CardImageContainerStyle}">
                                        <Image
                                            Source="{Binding UrlImagen}"
                                            Stretch="UniformToFill" />
                                    </Border>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button
                                            Grid.Column="0"
                                            Command="{Binding DataContext.RevisarComunidadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Revisar"
                                            Cursor="Hand"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Background="#F0A030"
                                            BorderThickness="0"
                                            Height="44">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="0,0,0,14">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter Property="Opacity" Value="0.9" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Button
                                            Grid.Column="1"
                                            Command="{Binding DataContext.AceptarComunidadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="Aceptar"
                                            Cursor="Hand"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Background="#27AE60"
                                            BorderThickness="0"
                                            Height="44">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="0,0,14,0">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter Property="Opacity" Value="0.9" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Revision modal overlay -->
        <Grid Visibility="{Binding ModalVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding CerrarModalCommand}"
                Cursor="Arrow"
                Focusable="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Rectangle Fill="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <local:RevisarComunidadUserControl
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DataContext="{Binding RevisarComunidadVM}" />
        </Grid>

        <!-- Detail modal overlay -->
        <Grid Visibility="{Binding ModalDetalleVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding CerrarModalCommand}"
                Cursor="Arrow"
                Focusable="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Rectangle Fill="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <local:DetalleComunidadUserControl
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DataContext="{Binding DetalleComunidadVM}" />
        </Grid>

        <!-- Aceptar confirmation modal overlay -->
        <Grid Visibility="{Binding ModalAceptarVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding CerrarModalAceptarCommand}"
                Cursor="Arrow"
                Focusable="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Rectangle Fill="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <local:ConfirmacionEliminacionModalUserControl
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DataContext="{Binding ConfirmacionAceptarVM}" />
        </Grid>
    </Grid>
</UserControl>
