<UserControl
    x:Class="PrototipadoEscritorio.Views.ListadoEventosUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PrototipadoEscritorio.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PrototipadoEscritorio.ViewModels.Eventos"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    UseLayoutRounding="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:ListadoEventosVM />
    </UserControl.DataContext>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Label
                Grid.Row="0"
                Margin="0,0,0,20"
                HorizontalAlignment="Center"
                Content="Eventos"
                FontSize="52" />

            <Grid
                Grid.Row="1"
                Width="600"
                Height="40"
                Margin="0,0,0,40">
                <Border
                    Padding="12,0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="#888"
                            Text="🔍" />
                        <TextBox
                            x:Name="SearchBox"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="14"
                            Text="{Binding TextoBusqueda, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>
                <TextBlock
                    Margin="48,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#999"
                    IsHitTestVisible="False"
                    Text="Buscar evento"
                    Visibility="{Binding Text.IsEmpty, ElementName=SearchBox, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto"
                SnapsToDevicePixels="True">

                <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding ListaEventos}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Width="520"
                                Height="100"
                                Margin="10"
                                Padding="0"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding
                                        Command="{Binding DataContext.VerDetalleEventoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Gesture="LeftClick" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect
                                                    BlurRadius="8"
                                                    Opacity="0.1"
                                                    ShadowDepth="2" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect
                                                            BlurRadius="18"
                                                            Opacity="0.22"
                                                            ShadowDepth="6" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column="0"
                                        Width="16"
                                        Background="{Binding ColorBorde}"
                                        CornerRadius="12,0,0,12" />

                                    <Grid Grid.Column="1" Margin="14,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Width="66"
                                            Height="66"
                                            Background="#F0F0F0"
                                            BorderBrush="#E0E0E0"
                                            BorderThickness="1"
                                            CornerRadius="33">
                                            <Border.Clip>
                                                <EllipseGeometry Center="33,33" RadiusX="33" RadiusY="33" />
                                            </Border.Clip>
                                            <Image
                                                Source="{Binding UrlImagenComunidad}"
                                                Stretch="UniformToFill" />
                                        </Border>

                                            <StackPanel
                                                Grid.Column="1"
                                                Margin="14,0,0,0"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="#888"
                                                    Text="{Binding NombreComunidadMostrar}" />
                                                <TextBlock
                                                    FontSize="17"
                                                    FontWeight="SemiBold"
                                                    Foreground="#333"
                                                    Text="{Binding Nombre}"
                                                    TextDecorations="Underline" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                FontSize="14"
                                                Foreground="#888"
                                                Text="{Binding Ubicacion}" />
                                        </StackPanel>
                                    </Grid>

                                    <Border
                                        Grid.Column="2"
                                        Width="130"
                                        Height="100"
                                        Background="#EFEAF4"
                                        ClipToBounds="True"
                                        CornerRadius="0,12,12,0">
                                        <Border.Clip>
                                            <RectangleGeometry
                                                RadiusX="12"
                                                RadiusY="12"
                                                Rect="0,0,130,100" />
                                        </Border.Clip>
                                        <Image Source="{Binding UrlImagen}" Stretch="UniformToFill" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid Visibility="{Binding ModalVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Button
                Background="Transparent"
                BorderThickness="0"
                Command="{Binding CerrarModalCommand}"
                Cursor="Arrow"
                Focusable="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Rectangle Fill="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <local:DetalleEventoUserControl
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DataContext="{Binding DetalleEventoVM}" />
        </Grid>
    </Grid>
</UserControl>
