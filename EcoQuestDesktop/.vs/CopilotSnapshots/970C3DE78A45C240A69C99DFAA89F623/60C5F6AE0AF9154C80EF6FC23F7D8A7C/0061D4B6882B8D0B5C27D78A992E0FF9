<UserControl
    x:Class="PrototipadoEscritorio.Views.ConfirmacionEliminacionModalUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PrototipadoEscritorio.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="200"
    d:DesignWidth="500"
    mc:Ignorable="d">

    <Border
        Background="White"
        BorderBrush="#E0E0E0"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Encabezado  -->
            <TextBlock
                Grid.Row="0"
                Background="#AF4C4E"
                FontSize="16"
                FontWeight="Bold"
                Foreground="White"
                Padding="15,12"
                Text="{Binding TituloModal}"
                TextAlignment="Center" />

            <!--  Mensaje de confirmación  -->
            <TextBlock
                Grid.Row="1"
                Margin="20,20,20,10"
                FontSize="14"
                Foreground="#333"
                Text="{Binding MensajeConfirmacion}"
                TextWrapping="Wrap"
                VerticalAlignment="Center" />

            <!--  Botones  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,0,15,15"
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <Button
                    Width="80"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="Black"
                    Command="{Binding CancelarCommand}"
                    Content="Cancelar"
                    Foreground="White" />

                <Button
                    Width="80"
                    Height="35"
                    Background="#AF4C4E"
                    Command="{Binding ConfirmarCommand}"
                    Content="Eliminar"
                    Foreground="White" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
